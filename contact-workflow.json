        "emailFormat": "html",
        "html": "=<!DOCTYPE html>\n<html>\n<head>\n    <style>\n        body { font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; }\n        .header { background: linear-gradient(135deg, #10b981, #06b6d4); color: white; padding: 20px; text-align: center; border-radius: 10px; margin-bottom: 20px; }\n        .content { padding: 20px; }\n        .info-box { background: #f8fafc; border: 2px solid #10b981; padding: 20px; margin: 20px 0; border-radius: 10px; }\n        .urgent-box { background: #fef2f2; border: 2px solid #dc2626; padding: 20px; margin: 20px 0; border-radius: 10px; }\n        .service-box { background: #ecfdf5; border: 2px solid #10b981; padding: 20px; margin: 20px 0; border-radius: 10px; }\n        .website-box { background: #eff6ff; border: 2px solid #3b82f6; padding: 20px; margin: 20px 0; border-radius: 10px; }\n        .automation-box { background: #faf5ff; border: 2px solid #a855f7; padding: 20px; margin: 20px 0; border-radius: 10px; }\n    </style>\n</head>\n<body>\n    <div class=\"header\">\n        <h1>🎯 New Client Inquiry</h1>\n        <h2>{{$node[\"Webhook - Portfolio Consultation1\"].json.body.name}}</h2>\n        <p>Source: tonyfyp.com Portfolio</p>\n    </div>\n    \n    <div class=\"content\">\n        <div class=\"urgent-box\">\n            <h3>⚡ ACTION REQUIRED:</h3>\n            <ul>\n                <li><strong>Respond within 24 hours</strong> as promised</li>\n                <li><strong>Review their service request:</strong> {{$node[\"Webhook - Portfolio Consultation1\"].json.body.type}}</li>\n                <li><strong>Prepare personalized response</strong> with relevant examples</li>\n            </ul>\n        </div>\n        \n        {{$node[\"Webhook - Portfolio Consultation1\"].json.body.type.startsWith('website') ? \n        '<div class=\"website-box\"><h3 style=\"color: #2563eb; margin: 0 0 15px 0;\">🌐 Website Service Request</h3><p><strong>Service Type:</strong> ' + $node[\"Webhook - Portfolio Consultation1\"].json.body.type + '</p><p><strong>Recommended Response:</strong></p><ul><li>Share relevant website portfolio examples</li><li>Discuss their business needs and target audience</li><li>Provide pricing starting at ₱5,000</li><li>Explain hosting & maintenance included</li></ul></div>' :\n        '<div class=\"automation-box\"><h3 style=\"color: #9333ea; margin: 0 0 15px 0;\">⚡ Automation Service Request</h3><p><strong>Service Type:</strong> ' + $node[\"Webhook - Portfolio Consultation1\"].json.body.type + '</p><p><strong>Recommended Response:</strong></p><ul><li>Share relevant automation case studies</li><li>Discuss workflow pain points</li><li>Present n8n automation solutions</li><li>Offer discovery call</li></ul></div>'}}\n        \n        <div class=\"info-box\">\n            <h3>📋 Contact Details:</h3>\n            <p><strong>Name:</strong> {{$node[\"Webhook - Portfolio Consultation1\"].json.body.name}}</p>\n            <p><strong>Email:</strong> {{$node[\"Webhook - Portfolio Consultation1\"].json.body.email}}</p>\n            <p><strong>Service Type:</strong> {{$node[\"Webhook - Portfolio Consultation1\"].json.body.type}}</p>\n        </div>\n        \n        <div class=\"info-box\">\n            <h3>💬 Their Message:</h3>\n            <p>{{$node[\"Webhook - Portfolio Consultation1\"].json.body.message || 'No specific message provided - follow up to understand their needs'}}</p>\n        </div>\n        \n        <div style=\"background: #fef3c7; padding: 20px; border-radius: 10px; margin: 20px 0;\">\n            <h3 style=\"color: #d97706;\">📞 Quick Actions:</h3>\n            <ul style=\"color: #92400e;\">\n                <li><a href=\"mailto:{{$node[\"Webhook - Portfolio Consultation1\"].json.body.email}}\">Reply to {{$node[\"Webhook - Portfolio Consultation1\"].json.body.name}}</a></li>\n                <li><a href=\"https://calendly.com/tony-opusautomations/30min\">Send Calendly Link</a></li>\n            </ul>\n        </div>\n    </div>\n</body>\n</html>",
